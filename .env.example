# =============================================================================
# Parking Violation Portal - Environment Variables Example
# =============================================================================
# Copy this file to `.env` and adjust values as needed.
# This file is loaded by docker-compose.yml and by the frontend Vite build.
# See .ai/ENVVAR_CONFIG.md for the full documentation of each variable.
# =============================================================================

# ---------- General ----------
APP_ENV=development
APP_NAME=Parking Violation Portal
APP_PORT=8080

# ---------- PostgreSQL ----------
POSTGRES_DB=parking_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Optional: full DATABASE_URL. If set, services prefer this.
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/parking_portal?sslmode=disable

# ---------- JWT ----------
# IMPORTANT: must be at least 32 characters. Change in production.
JWT_SECRET=super-secret-key-for-development-min-32-chars
JWT_EXPIRATION_HOURS=24

# ---------- RabbitMQ ----------
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_EXCHANGE=parking.events
RABBITMQ_NOTIFICATION_QUEUE=notification.queue

# ---------- File Upload (PHOTO_STORAGE.md) ----------
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=5
PUBLIC_UPLOAD_URL=/uploads

# ---------- Notification Worker ----------
WORKER_CONCURRENCY=1
WORKER_RETRY_COUNT=3

# ---------- Frontend (Vite, read at build time) ----------
VITE_API_URL=http://localhost:8080/api/v1
VITE_APP_NAME=Parking Violation Portal

# ---------- Service URLs (used by gateway for routing) ----------
# In docker-compose these are overridden with Docker service names.
# Outside docker (e.g. local Go dev), point at localhost.
VIOLATION_SERVICE_URL=http://localhost:8081
PAYMENT_SERVICE_URL=http://localhost:8082

MIDTRANS_SERVER_KEY=SB-Mid-server-XVkeSQW-v9dG1TJa29FbjxXG
MIDTRANS_ENV=sandbox
# Comma-separated list of enabled payment methods for Snap.
# Allowed values: gopay, qris, shopeepay, dana, ovo, bca_va, bni_va, etc.
# See .ai/ENVVAR_CONFIG.md for the full list.
MIDTRANS_ENABLED_METHODS=qris,gopay
# Where Midtrans should POST the payment notification (webhook).
# In Docker this must be reachable from Midtrans's servers; for local dev
# use an ngrok URL or skip the webhook (poll via /payments/{id}).
MIDTRANS_NOTIFICATION_URL=
MIDTRANS_RETURN_URL=
# Polling/timeout settings
MIDTRANS_HTTP_TIMEOUT_SECONDS=10
MIDTRANS_POLL_INTERVAL_SECONDS=5
MIDTRANS_MAX_POLL_SECONDS=60
