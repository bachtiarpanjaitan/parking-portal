        <mxCell id="flows_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=10;verticalAlign=top;spacingTop=5;" value="" vertex="1">
          <mxGeometry height="255" width="700" x="80" y="960" as="geometry" />
        </mxCell>
        <mxCell id="flows_title" parent="1" style="text;html=1;fontSize=12;align=left;" value="&lt;b&gt;Core Data Flows&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="200" x="95" y="965" as="geometry" />
        </mxCell>
        <mxCell id="flow1" parent="1" style="text;html=1;fontSize=9;align=left;whiteSpace=wrap;" value="&lt;b&gt;Flow 1 — Issue Violation:&lt;/b&gt; Officer → Upload Photo → Create Violation → Fine Engine (versioned rules + time window + repeat multiplier) → Auto-create Invoice → Publish violation.created + invoice.created" vertex="1">
          <mxGeometry height="38" width="670" x="95" y="988" as="geometry" />
        </mxCell>
        <mxCell id="flow2" parent="1" style="text;html=1;fontSize=9;align=left;whiteSpace=wrap;" value="&lt;b&gt;Flow 2 — Pay Invoice:&lt;/b&gt; Member → POST /payments/snap-token → Midtrans Snap → Create Snap Transaction → Return Token → window.snap.pay() → Midtrans Webhook → Update Payment + Invoice Status → Publish payment.succeeded/failed" vertex="1">
          <mxGeometry height="38" width="670" x="95" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="flow3" parent="1" style="text;html=1;fontSize=9;align=left;whiteSpace=wrap;" value="&lt;b&gt;Flow 3 — View History:&lt;/b&gt; Member/Officer → GET /history → 5-table JOIN (violations ⨝ fine_rule_versions ⨝ invoices ⨝ LATERAL payments) → Returns frozen rule version + calculation_snapshot + payment status" vertex="1">
          <mxGeometry height="38" width="670" x="95" y="1072" as="geometry" />
        </mxCell>
        <mxCell id="flow4" parent="1" style="text;html=1;fontSize=9;align=left;whiteSpace=wrap;" value="&lt;b&gt;Flow 4 — Manage Rules:&lt;/b&gt; Officer → CRUD Rule Versions → Draft → Publish → Atomic Activation (partial unique index on is_active = true) → New violations use active version, historical violations retain frozen version" vertex="1">
          <mxGeometry height="38" width="670" x="95" y="1114" as="geometry" />
        </mxCell>
        <mxCell id="flow5" parent="1" style="text;html=1;fontSize=9;align=left;whiteSpace=wrap;" value="&lt;b&gt;Flow 5 — Notification Worker:&lt;/b&gt; RabbitMQ → Consume 5 Event Types → Check processed_events (idempotency) → Create notification → Log structured event → Best-effort delivery; request succeeds even if broker is down (ADR-011)" vertex="1">
          <mxGeometry height="38" width="670" x="95" y="1156" as="geometry" />
        </mxCell>
        <mxCell id="notes_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=10;verticalAlign=top;spacingTop=5;" value="" vertex="1">
          <mxGeometry height="255" width="700" x="820" y="960" as="geometry" />
        </mxCell>
        <mxCell id="notes_title" parent="1" style="text;html=1;fontSize=12;align=left;" value="&lt;b&gt;Architecture Principles &amp; Design Decisions&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="400" x="835" y="965" as="geometry" />
        </mxCell>
        <mxCell id="notes_content" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" value="&lt;div style=&#39;text-align:left;font-size:9px;line-height:1.6;&#39;&gt;&lt;b&gt;ADR-004:&lt;/b&gt; Calculation Snapshot — Fine breakdown frozen as JSONB on violation creation.&lt;br&gt;&lt;b&gt;ADR-005:&lt;/b&gt; One Invoice Per Violation — 1:1 relationship, no partial payments.&lt;br&gt;&lt;b&gt;ADR-006:&lt;/b&gt; bcrypt Authentication — Uniform 401 on any auth failure.&lt;br&gt;&lt;b&gt;ADR-008:&lt;/b&gt; Notification Worker — Separate consumer, RabbitMQ topic exchange.&lt;br&gt;&lt;b&gt;ADR-009:&lt;/b&gt; API Gateway — Single entrypoint, JWT validation, reverse proxy.&lt;br&gt;&lt;b&gt;ADR-010:&lt;/b&gt; Local FS Storage — Photos on Docker volume (no S3/MinIO).&lt;br&gt;&lt;b&gt;ADR-011:&lt;/b&gt; Best-Effort Events — Fire after DB commit; failure logged, not fatal.&lt;br&gt;&lt;b&gt;ADR-012:&lt;/b&gt; Real Midtrans — Snap sandbox + mock fallback (MOCK_* prefix).&lt;br&gt;&lt;b&gt;ADR-013:&lt;/b&gt; Minimal Infra — No Redis, K8s, gRPC, or service mesh.&lt;/div&gt;" vertex="1">
          <mxGeometry height="215" width="670" x="835" y="988" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
