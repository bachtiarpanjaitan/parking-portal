          <mxGeometry height="20" width="300" x="1395" y="125" as="geometry" />
        </mxCell>
        <mxCell id="snapshot_json" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" value="&lt;div style=&quot;text-align:left;font-size:9px;line-height:1.4;font-family:monospace;&quot;&gt;{&lt;br&gt;  &amp;quot;base_amount&amp;quot;: 50000,&lt;br&gt;  &amp;quot;violation_type&amp;quot;: &amp;quot;no_parking_zone&amp;quot;,&lt;br&gt;  &amp;quot;time_category&amp;quot;: &amp;quot;day&amp;quot;,&lt;br&gt;  &amp;quot;time_multiplier&amp;quot;: 1.0,&lt;br&gt;  &amp;quot;repeat_count&amp;quot;: 0,&lt;br&gt;  &amp;quot;repeat_multiplier&amp;quot;: 1.0,&lt;br&gt;  &amp;quot;fine_amount&amp;quot;: 50000,&lt;br&gt;  &amp;quot;rule_version_id&amp;quot;: &amp;quot;...&amp;quot;,&lt;br&gt;  &amp;quot;rule_version_number&amp;quot;: 1,&lt;br&gt;  &amp;quot;calculated_at&amp;quot;: &amp;quot;2026-01-01T10:00:00Z&amp;quot;&lt;br&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="300" x="1395" y="148" as="geometry" />
        </mxCell>
