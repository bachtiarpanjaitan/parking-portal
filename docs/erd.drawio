        <mxCell id="calc_title" parent="1" style="text;html=1;fontSize=11;align=left;" value="&lt;b&gt;Fine Calculation Engine&lt;/b&gt; (Flow 1 — Issue Violation)" vertex="1">
          <mxGeometry height="20" width="400" x="535" y="1025" as="geometry" />
        </mxCell>
        <mxCell id="calc_formula" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" value="&lt;div style=&#39;text-align:left;font-size:9px;line-height:1.5;&#39;&gt;&lt;b&gt;fine_amount = base_amount × time_multiplier × repeat_multiplier&lt;/b&gt;&lt;br&gt;• &lt;b&gt;Time Multiplier:&lt;/b&gt; Day (06:00–21:59) → day_multiplier | Night (22:00–05:59) → night_multiplier&lt;br&gt;• &lt;b&gt;Repeat Multiplier:&lt;/b&gt; Query violations for same plate in last 90 days → repeat_0 (0), repeat_1 (1), repeat_2_plus (2+)&lt;br&gt;• The complete breakdown is stored as &lt;b&gt;calculation_snapshot&lt;/b&gt; (JSONB) — immutable after creation (ADR-004)&lt;/div&gt;" vertex="1">
          <mxGeometry height="45" width="750" x="535" y="1048" as="geometry" />
        </mxCell>
        <mxCell id="event_box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;spacingTop=5;" value="" vertex="1">
          <mxGeometry height="270" width="330" x="1380" y="880" as="geometry" />
        </mxCell>
        <mxCell id="event_title" parent="1" style="text;html=1;fontSize=11;align=left;" value="&lt;b&gt;Event Types (RabbitMQ)&lt;/b&gt;" vertex="1">
          <mxGeometry height="20" width="300" x="1410" y="885" as="geometry" />
        </mxCell>
        <mxCell id="event_list" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" value="&lt;div style=&#39;text-align:left;font-size:9px;line-height:1.6;&#39;&gt;Exchange: &lt;b&gt;parking.events&lt;/b&gt; (topic)&lt;br&gt;Queue: &lt;b&gt;notification.queue&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. &lt;b&gt;violation.created&lt;/b&gt;&lt;br&gt;   → Published by Violation Service&lt;br&gt;2. &lt;b&gt;invoice.created&lt;/b&gt;&lt;br&gt;   → Published by Violation Service&lt;br&gt;3. &lt;b&gt;payment.succeeded&lt;/b&gt;&lt;br&gt;   → Published by Payment Service&lt;br&gt;4. &lt;b&gt;payment.failed&lt;/b&gt;&lt;br&gt;   → Published by Payment Service&lt;br&gt;5. &lt;b&gt;rule.published&lt;/b&gt;&lt;br&gt;   → Published by Violation Service&lt;br&gt;&lt;br&gt;Each event has: event_id, event_type,&lt;br&gt;occurred_at, payload (see pkg/events)&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="300" x="1410" y="905" as="geometry" />
        </mxCell>
